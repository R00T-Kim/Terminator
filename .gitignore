# ============================================
# Terminator - Public Repository .gitignore
# ============================================

# --- Secrets & Auth ---
.env
.env.*
!.env.example
.claude_auth/

# --- Personal / Session data ---
.terminator.history
.terminator.log
.terminator.pid
nohup.out

# --- Local tool configs (contain hardcoded paths) ---
.mcp.json
.gemini/
.playwright-mcp/

# --- Virtual environment ---
venv/
.venv/

# --- Python cache ---
__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/

# --- Challenge binaries & wargame data ---
tests/wargames/*.zip
tests/wargames/extracted/
tests/wargames/hunter/

# --- Bug bounty targets (sensitive data + large cloned repos) ---
targets/
namuhx*

# --- Knowledge: sensitive operational data ---
knowledge/bugbounty/
knowledge/challenges/
knowledge/contracts/
knowledge/knowledge.db
knowledge/knowledge.db-shm
knowledge/knowledge.db-wal

# --- Bulk URL lists (generated, not source) ---
tools/awesome_hacking_*_urls*.txt
tools/awesome_hacking_retry_jina.txt
tools/wave2_*.txt

# --- Challenge artifacts (temporary, overwritten per challenge) ---
challenges/
solve.py
reversal_map.md
trigger_report.md
trigger_poc.py
chain_report.md
critic_review.md

# --- Legacy code (not part of v3 architecture) ---
agent/
bridge/
rag_system/
aiedge_handoff_adapter.py

# --- OMC state ---
.omc/
.omx/*
!.omx/hooks/
!.omx/hooks/**

# --- Shared coordination runtime state ---
coordination/sessions/
coordination/cache/

# --- Reports (auto-generated) ---
reports/

# --- OS files ---
.DS_Store
*.swp
*.swo
Thumbs.db

# --- Database ---
db/

# --- Agent logs ---
agent_logs/

# --- Temp files ---
*.tmp
/tmp/

# --- Build artifacts ---
BUILD_VALIDATION_REPORT.md

# --- Research: target-specific analysis ---
research/doordash_*.md
research/FINDINGS.md

# --- GraphRAG (large generated data, keep code only) ---
tools/graphrag-security/input/
tools/graphrag-security/input_backup/
tools/graphrag-security/output/
tools/graphrag-security/cache/
tools/graphrag-security/logs/
tools/graphrag-security/STATUS.md

# --- AI Edge runs ---
aiedge-runs/

# --- Private setup script ---
setup.sh
.setup.log

# --- Target artifacts (sensitive) ---
target_assessment.md
*.sa.bin
*.bin.fw
poc_step*.png
output/
.sisyphus/
.playwright-cli/
tools/graphrag-security/update_output/

# --- Firmware binaries (large + sensitive) ---
FW_*.zip
BC800Z*
arm_gpu_bug_bounty*

# --- Misc ---
ref.md
research/vpn_client_attack_techniques.md
.claude_auth/
.env
echo
<%*
EXIT:
Exit code:\ 
knowledge/index.md
.mcp.json
